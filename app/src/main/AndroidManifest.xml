<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.charonviz.medscope">
    <uses-permission android:name="android.permission.INTERNET" />
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.MedScope">
        <activity android:name=".ui.SplashActivity" android:exported="true"
            android:theme="@style/Theme.MedScope.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".ui.MainActivity" />
        <activity android:name=".ui.DiagnosisActivity" />
        <activity android:name=".ui.MedicineActivity" />
        <activity android:name=".ui.AiChatActivity" />
        <activity android:name=".ui.SettingsActivity" />
    </application>
</manifest>
