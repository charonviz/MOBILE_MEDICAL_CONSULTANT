<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:paddingVertical="3dp" android:paddingHorizontal="10dp">
    <TextView android:id="@+id/tv_message"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:maxWidth="260dp" android:layout_gravity="end"
        android:background="@drawable/bg_bubble_user"
        android:paddingHorizontal="14dp" android:paddingVertical="10dp"
        android:textSize="15sp" android:textColor="#ffffff" android:lineSpacingExtra="2dp"/>
</FrameLayout>
